PORT=3000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/credit_disputor?schema=public"

JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# HMAC secret for 4-digit email OTP codes (use a long random string)
OTP_CODE_SECRET=change-me-otp-hmac-secret

# OTP and password-reset link TTLs (ms-compatible, e.g. 10m, 1h)
OTP_TTL_MS=10m
PASSWORD_RESET_TTL_MS=1h

# Email: use "console" for local dev (logs only); use "resend" in production
EMAIL_PROVIDER=console
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# No trailing slash; used for password reset links (/?token=...)
FRONTEND_URL=http://localhost:5173

# Public URL of this API (no trailing slash). Used for logo in HTML emails (e.g. https://api.example.com).
# Leave empty in dev to default to http://localhost:PORT (images may not load in real inboxes until set).
PUBLIC_API_URL=

LOG_LEVEL=info
LOG_PRETTY=false

# Used by docker-compose.yml (optional overrides)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=credit_disputor
