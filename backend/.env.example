NODE_ENV=development
PORT=3000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/credit_disputor?schema=public"

JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
# Step-up token after password sign-in until MFA completes (same JWT_SECRET)
JWT_MFA_EXPIRES_IN=10m
REFRESH_TOKEN_EXPIRES_IN=7d

OTP_CODE_SECRET=change-me-otp-hmac-secret

OTP_TTL_MS=10m
PASSWORD_RESET_TTL_MS=1h

EMAIL_PROVIDER=console
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Next.js test SPA (npm run dev in frontend/) uses this origin; CORS allows localhost in development.
FRONTEND_URL=http://localhost:5173

# Generate: openssl rand -hex 32
TOTP_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# Bureau wizard PII at rest (identity, address, Experian tokens); use a distinct key in production.
PII_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Experian Connect (UC-06). Use EXPERIAN_MOCK=true for local dev without calling Experian.
EXPERIAN_MOCK=false
EXPERIAN_CLIENT_ID=
EXPERIAN_CLIENT_SECRET=
EXPERIAN_USERNAME=
EXPERIAN_PASSWORD=
EXPERIAN_TOKEN_URL=https://sandbox-us-api.experian.com/oauth2/v1/token
EXPERIAN_CONNECT_BASE_URL=https://sandbox-us-api.experian.com/connectapi
EXPERIAN_CONNECT_PRODUCT_ID=38
EXPERIAN_CONNECT_PURPOSE_TYPE=7
EXPERIAN_CONNECT_RISK_MODEL=VP
EXPERIAN_HTTP_TIMEOUT_MS=30000

WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Credit Disputor
WEBAUTHN_ORIGIN=http://localhost:5173

GOOGLE_CLIENT_ID=

# Twilio Verify v2 (SMS). Use console in dev without Twilio — verification code is always 000000.
TWILIO_VERIFY_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
# ISO country for parsing national numbers at signup / PATCH profile (libphonenumber-js)
TWILIO_PHONE_DEFAULT_REGION=ET

PUBLIC_API_URL=

LOG_LEVEL=info
# Human-readable lines in the terminal (recommended in development); applies to startup logs and pino-http request lines.
LOG_PRETTY=false

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=credit_disputor
