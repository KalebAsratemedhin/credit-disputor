PORT=3000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/credit_disputor?schema=public"

JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

LOG_LEVEL=info
LOG_PRETTY=false

# Used by docker-compose.yml (optional overrides)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=credit_disputor
