generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EmailOtpPurpose {
  SIGNUP_VERIFY
  SIGNIN
}

enum WebAuthnChallengeKind {
  REGISTRATION
  AUTHENTICATION
}

enum BureauConnectionState {
  AWAITING_IDENTITY
  AWAITING_ADDRESS
  AWAITING_CONSENT
  AWAITING_EXPERIAN_KIQ
  PROCESSING
  COMPLETE
  FAILED
}

enum BureauCode {
  EXPERIAN
  TRANSUNION
  EQUIFAX
}

enum BureauPullJobStatus {
  PENDING
  PENDING_PROVIDER
  IN_FLIGHT
  COMPLETE
  FAILED
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  passwordHash         String?
  fullName             String
  phoneNumber          String?
  googleSub            String?               @unique
  avatarUrl            String?
  emailVerified        Boolean               @default(false)
  phoneVerified        Boolean               @default(false)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  refreshTokens        RefreshToken[]
  emailOtpChallenges   EmailOtpChallenge[]
  passwordResetTokens  PasswordResetToken[]
  userTotp             UserTotp?
  backupCodes          UserBackupCode[]
  webauthnCredentials  WebAuthnCredential[]
  webauthnChallenges   WebAuthnChallenge[]
  preferences          UserPreference[]
  bureauConnections    BureauConnection[]
  scoreSnapshots       ScoreSnapshot[]
}

model UserPreference {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  key       String
  value     Boolean
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
  @@index([userId])
}

model UserTotp {
  userId    String    @id
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  secretEnc String
  enabled   Boolean   @default(false)
  verifiedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model UserBackupCode {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  usedAt    DateTime?
  batchId   String
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([userId, batchId])
}

model WebAuthnCredential {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId String   @unique
  publicKey    Bytes
  counter      BigInt   @default(0)
  transports   String?
  nickname     String
  createdAt    DateTime @default(now())

  @@index([userId])
}

model WebAuthnChallenge {
  id        String                 @id @default(cuid())
  userId    String
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge String
  kind      WebAuthnChallengeKind
  expiresAt DateTime
  createdAt DateTime               @default(now())

  @@index([userId, kind])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model EmailOtpChallenge {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose      EmailOtpPurpose
  codeHash     String
  expiresAt    DateTime
  attemptCount Int               @default(0)
  consumedAt   DateTime?
  createdAt    DateTime          @default(now())

  @@index([userId, purpose])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model BureauConnection {
  id                       String                @id @default(cuid())
  userId                   String
  user                     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  state                    BureauConnectionState @default(AWAITING_IDENTITY)
  institutionId            String?
  identityPayloadEnc       String?
  addressPayloadEnc        String?
  experianAuthSessionEnc   String?
  experianConsumerTokenEnc String?
  experianKiqPayloadEnc    String?
  lastProviderPollAt       DateTime?
  userSafeFailureCode      String?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  consent                  BureauConsentRecord?
  pullJobs                 BureauPullJob[]

  @@index([userId])
  @@index([userId, state])
}

model BureauConsentRecord {
  id               String           @id @default(cuid())
  connectionId     String           @unique
  connection       BureauConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  userId           String
  agreementVersion String
  textHash         String?
  agreedAt         DateTime

  @@index([userId])
}

model BureauPullJob {
  id           String              @id @default(cuid())
  connectionId String
  connection   BureauConnection    @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  bureau       BureauCode
  status       BureauPullJobStatus @default(PENDING)
  providerRef  String?
  errorCode    String?
  updatedAt    DateTime            @updatedAt

  @@unique([connectionId, bureau])
  @@index([connectionId])
}

model ScoreSnapshot {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  connectionId String
  bureau       BureauCode
  score        Int
  scoreType    String
  capturedAt   DateTime   @default(now())

  @@index([userId, bureau, capturedAt])
  @@index([connectionId])
}
