generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EmailOtpPurpose {
  SIGNUP_VERIFY
  SIGNIN
}

enum WebAuthnChallengeKind {
  REGISTRATION
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  passwordHash         String?
  fullName             String
  phoneNumber          String?
  googleSub            String?               @unique
  avatarUrl            String?
  emailVerified        Boolean               @default(false)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  refreshTokens        RefreshToken[]
  emailOtpChallenges   EmailOtpChallenge[]
  passwordResetTokens  PasswordResetToken[]
  userTotp             UserTotp?
  backupCodes          UserBackupCode[]
  webauthnCredentials  WebAuthnCredential[]
  webauthnChallenges   WebAuthnChallenge[]
}

model UserTotp {
  userId    String    @id
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  secretEnc String
  enabled   Boolean   @default(false)
  verifiedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model UserBackupCode {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  usedAt    DateTime?
  batchId   String
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([userId, batchId])
}

model WebAuthnCredential {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId String   @unique
  publicKey    Bytes
  counter      BigInt   @default(0)
  transports   String?
  nickname     String
  createdAt    DateTime @default(now())

  @@index([userId])
}

model WebAuthnChallenge {
  id        String                 @id @default(cuid())
  userId    String
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge String
  kind      WebAuthnChallengeKind
  expiresAt DateTime
  createdAt DateTime               @default(now())

  @@index([userId, kind])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model EmailOtpChallenge {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose      EmailOtpPurpose
  codeHash     String
  expiresAt    DateTime
  attemptCount Int               @default(0)
  consumedAt   DateTime?
  createdAt    DateTime          @default(now())

  @@index([userId, purpose])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}
